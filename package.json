{
  "name": "@strattlabs/agent-readiness-manifest",
  "version": "0.1.1",
  "description": "An open, declaration-only spec and reference validator for the Agent Readiness Manifest — a single well-known descriptor that points to a site's agent-relevant resources.",
  "keywords": [
    "agent-readiness",
    "manifest",
    "well-known",
    "ai-agents",
    "discovery",
    "declaration",
    "spec",
    "json-schema"
  ],
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=18.18"
  },
  "bin": {
    "agent-readiness": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": "./schema/agent-readiness.schema.json"
  },
  "files": [
    "dist",
    "schema",
    "SPEC.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/strattlabs/agent-readiness-manifest.git"
  },
  "homepage": "https://github.com/strattlabs/agent-readiness-manifest#readme",
  "bugs": {
    "url": "https://github.com/strattlabs/agent-readiness-manifest/issues"
  },
  "author": "Stratt Labs <oss@strattlabs.com>"
}
